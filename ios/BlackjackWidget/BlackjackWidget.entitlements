<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  App Group (Slice 4.3) — shared with the app so the widget can read the
	  stats snapshot the app writes. Must match the app's group and be enabled
	  for both App IDs in the Apple Developer portal (a pending human action).
	  Inert with code signing off, so the simulator build stays green.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.arthurzhang.blackjacktrainer</string>
	</array>
</dict>
</plist>
