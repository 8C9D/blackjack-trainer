# SwiftFormat config — the Swift analogue of the web repo's prettier gate.
--swiftversion 5.9
--indent 4
--maxwidth 100
--commas inline
--self remove
--importgrouping testable-bottom

# Keep the opening brace on the same line as a wrapped signature/condition so
# SwiftFormat and SwiftLint's opening_brace rule agree.
--disable wrapMultilineStatementBraces

# Generated project & exported fixtures must not be reformatted.
--exclude BlackjackTrainer.xcodeproj,Fixtures
