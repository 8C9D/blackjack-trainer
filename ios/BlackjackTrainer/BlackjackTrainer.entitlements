<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  iCloud Key-Value Store (Slice 4.2). Enables NSUbiquitousKeyValueStore to
	  sync the per-trainer stats across a user's devices. The capability must be
	  enabled for the App ID in the Apple Developer portal and the app signed with
	  a matching provisioning profile (a pending human action). Until then the app
	  degrades to local-only with no code change.
	-->
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
	<!--
	  App Group (Slice 4.3). Lets the app and the widget extension share one
	  UserDefaults container for the stats snapshot. The group must be enabled
	  for both App IDs in the Apple Developer portal and the targets signed (a
	  pending human action). Until then `UserDefaults(suiteName:)` falls back to
	  a per-process store, so the simulator build stays green and the widget
	  shows live data only once the group is provisioned on device.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.arthurzhang.blackjacktrainer</string>
	</array>
</dict>
</plist>
